# frozen_string_literal: true

source "https://rubygems.org"

# Specify your gem's dependencies in active_module.gemspec
gemspec

gem "rake", "> 13.0"

gem "rspec", "> 3.0"

gem "rubocop", "> 1", require: false
gem "rubocop-rspec", "> 2", require: false
gem "simplecov", require: false
gem 'zeitwerk', "> 2"

gem "byebug", "> 11"
gem 'rdoc', ">6"
